{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Pawn",
            "type": "process",
            "command": "${workspaceFolder}/pawno/pawncc.exe",
            "args": [
                "${file}",
                "-i${workspaceFolder}/pawno/include",
                "-o${workspaceFolder}/gamemodes/${fileBasenameNoExtension}",
                "-;+",
                "-(+",
                "-d3"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
